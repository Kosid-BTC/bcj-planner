@tailwind base;
@tailwind components;
@tailwind utilities;

/* การตั้งค่าพื้นฐานสำหรับ UI มหาอำนาจ */
:root {
  font-family: 'Inter', system-ui, -apple-system, sans-serif;
  line-height: 1.5;
  font-weight: 400;
  
  background-color: #F8FAFC; /* Slate 50 - สีพื้นหลังสะอาดตา */
  color: #0F172A;           /* Slate 900 - สีตัวอักษรที่อ่านง่ายที่สุด */

  font-synthesis: none;
  text-rendering: optimizeLegibility;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
}

body {
  margin: 0;
  display: flex;
  min-width: 320px;
  min-height: 100vh;
}

#root {
  width: 100%;
}

/* --- Utility: Antigravity Smoothness --- */

/* ซ่อน Scrollbar สำหรับ Element ที่ต้องการความคลีน (เช่น Sidebar) */
.no-scrollbar::-webkit-scrollbar {
  display: none;
}

.no-scrollbar {
  -ms-overflow-style: none;  /* IE and Edge */
  scrollbar-width: none;  /* Firefox */
}

/* เอฟเฟกต์การเลือกข้อความ (Brand Color) */
::selection {
  background-color: #1A56DB; /* Blue 700 */
  color: white;
}

/* Custom Scrollbar สำหรับส่วนเนื้อหาหลัก */
::-webkit-scrollbar {
  width: 6px;
}

::-webkit-scrollbar-track {
  background: #f1f5f9;
}

::-webkit-scrollbar-thumb {
  background: #cbd5e1;
  border-radius: 10px;
}

::-webkit-scrollbar-thumb:hover {
  background: #94a3b8;
}
